{
  "name": "backend",
  "version": "1.0.0",
  "description": "Bado CRM Backend ",
  "main": "src/app.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
